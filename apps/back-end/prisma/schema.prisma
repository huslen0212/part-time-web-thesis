generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/* ================= ENUMS ================= */

enum UserRole {
  JOB_SEEKER
  EMPLOYER
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCEL
}

enum RequestType {
  JOB_REQUEST
  JOB_INVITE
}

enum NotificationType {
  REQUEST_CREATED
  REQUEST_APPROVED
  REQUEST_REJECTED
  REQUEST_CANCELLED
  JOB_INVITED
}

enum Gender {
  MALE
  FEMALE
}

/* ================= MODELS ================= */

model User {
  userId    Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      UserRole
  createdAt DateTime @default(now())

  jobSeeker JobSeeker?
  employer  Employer?

  ratingsGiven    Rating[] @relation("RatingFromUser")
  ratingsReceived Rating[] @relation("RatingToUser")

  notifications Notification[]
}

/* ================= JOB SEEKER ================= */

model JobSeeker {
  jobseekerId Int @id
  userName    String?
  phoneNumber String?
  birthDate   DateTime?
  gender      Gender?
  address     String?

  skills String? @db.VarChar(250)

  interestedCategoryId Int?
  interestedCategory   Category? @relation(fields: [interestedCategoryId], references: [categoryId])

  createdAt DateTime @default(now())

  user     User     @relation(fields: [jobseekerId], references: [userId])
  requests Request[]

  availabilities AvailabilityTime[]
}

/* ================= AVAILABILITY ================= */

model AvailabilityTime {
  id Int @id @default(autoincrement())

  jobSeekerId Int
  day         Int
  startTime   DateTime
  endTime     DateTime

  jobSeeker JobSeeker @relation(fields: [jobSeekerId], references: [jobseekerId])

  @@index([jobSeekerId, day])
}

/* ================= EMPLOYER ================= */

model Employer {
  employerId   Int    @id
  employerName String?
  phoneNumber  String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [employerId], references: [userId])
  jobs Job[]
}

/* ================= CATEGORY ================= */

model Category {
  categoryId Int    @id @default(autoincrement())
  name       String @unique

  jobs Job[]
  jobSeekers JobSeeker[]
}

/* ================= JOB ================= */

model Job {
  jobId       Int      @id @default(autoincrement())
  title       String
  description String
  location    String
  latitude    Float?
  longitude   Float?
  salary      Int
  startTime   DateTime
  endTime     DateTime
  numberOfWorker Int?
  isTemplate  Boolean  @default(false)
  createdAt   DateTime @default(now())

  employerId Int
  employer   Employer @relation(fields: [employerId], references: [employerId])

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [categoryId])

  requests Request[]
  ratings  Rating[]
}

/* ================= REQUEST ================= */

model Request {
  requestId   Int           @id @default(autoincrement())
  status      RequestStatus @default(PENDING)
  type        RequestType   @default(JOB_REQUEST)
  createdAt   DateTime      @default(now())
  workerCount Int           @default(1)

  jobSeekerId Int
  jobId       Int

  jobSeeker JobSeeker @relation(fields: [jobSeekerId], references: [jobseekerId])
  job       Job       @relation(fields: [jobId], references: [jobId])

  @@unique([jobSeekerId, jobId])
}

/* ================= RATING ================= */

model Rating {
  ratingId Int @id @default(autoincrement())

  fromUserId Int
  toUserId   Int
  jobId      Int
  score      Int
  comment    String?

  createdAt DateTime @default(now())

  fromUser User @relation("RatingFromUser", fields: [fromUserId], references: [userId])
  toUser   User @relation("RatingToUser", fields: [toUserId], references: [userId])
  job      Job  @relation(fields: [jobId], references: [jobId])

  @@unique([fromUserId, toUserId, jobId])
}

/* ================= NOTIFICATION ================= */

model Notification {
  notificationId Int @id @default(autoincrement())

  userId  Int
  title   String
  message String
  type    NotificationType

  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [userId])
}